{
  "name": "bible-arvr-app",
  "version": "0.1.0",
  "description": "Bible AR/VR Application",
  "main": "Scripts/index.js",
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "Scripts/**/*.js",
      "!Scripts/**/__tests__/**"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 80,
        "functions": 80,
        "branches": 75,
        "statements": 80
      }
    },
    "coverageReporters": ["text", "lcov", "html"]
  },
  "devDependencies": {
    "jest": "^29.7.0"
  }
}
