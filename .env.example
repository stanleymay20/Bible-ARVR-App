# Bible AR/VR App — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── API.Bible ────────────────────────────────────────────────────────────────
# Required. Obtain a free key at https://scripture.api.bible
BIBLE_API_KEY=your_api_key_here

# Optional. Defaults to KJV (de4e12af7f28f599-02) if not set.
# Other IDs:
#   NIV  → 78a9f6124f344018-01
#   ESV  → 9879dbb7cfe39e4d-04
#   NLT  → 65eec8e0b60e656b-01
#   NASB → f72b840c855f362c-04
#   WEB  → 9879dbb7cfe39e4d-01  (public domain, no key restrictions)
BIBLE_ID=de4e12af7f28f599-02
